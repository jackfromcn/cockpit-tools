                  className={`flex items-center gap-2 px-3 py-2 ${isDark ? 'bg-purple-500/20 hover:bg-purple-500/30 text-purple-300' : 'bg-purple-50 hover:bg-purple-100 text-purple-600'} rounded-xl transition-colors text-sm`}
