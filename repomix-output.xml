  }
]`}
                  className={`w-full px-3 py-2 rounded-xl border ${colors.cardBorder} ${isDark ? 'bg-white/5' : 'bg-gray-50'} ${colors.text} text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-500/30 resize-none`}
