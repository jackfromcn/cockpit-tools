                  {t('mcpManager.disabled')}
                </span>
              )}
            </div>
            
            {/* 命令 */}
            <div className={`flex items-center gap-1.5 mt-1 ${colors.textMuted} ${isDisabled ? 'opacity-50' : ''}`}>
              <Terminal size={14} />
              <code className="text-sm truncate">{commandStr}</code>
