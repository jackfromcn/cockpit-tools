      const restored = await invoke('restore_machine_guid')
      setSystemMachineInfo(prev => ({ ...prev, machineGuid: restored }))
      await showSuccess(t('settings.restoreSuccess'), `${t('settings.machineGuidRestored')}: ${restored}`)
